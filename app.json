{
  "expo": {
    "name": "mobileApp",
    "owner": "hoangmobiledev",
    "slug": "mobileApp",
    "scheme": "mobileapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.giahoang.mobileui",
      "supportsTablet": true
    },
    "android": {
      "package": "com.giahoang.mobileui",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2ac2054d-c570-4456-97bd-d478841d378a"
      }
    },
    "plugins": [
    ]
  }
}

{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "skipLibCheck": true,
    "types": ["react", "react-native"],
    "paths": {
      "@assets/*": ["assets/*"],
      "@components/*": ["src/components/*"],
      "@screens/*": ["src/screens/*"],
      "@utils/*": ["src/utils/*"],
      "@services/*": ["src/services/*"],
      "@constants/*": ["src/constants/*"]
    }
  },
  "exclude": [
    "node_modules",
    "clerk-expo-backup",
    "babel.config.js",
    "metro.config.js"
  ]
}
